# Blender
*.blend1
*.blend2
# oslc drops the compiled cache next to the .osl at render/compile time;
# Cycles rebuilds it on demand, and a stale one is a subtle failure mode.
*.oso

# Render / bundle output (generated at runtime, never committed)
/out/
/_bundles/
/tests/_out/
# NB: do NOT blanket-ignore *.png — icon.png (button) and committed fixtures stay.

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
